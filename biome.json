{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "packages/app/src/**/*",
      "packages/app/vite.config.ts",

      "packages/docs/src/**/*",
      "packages/docs/vite.config.ts",
      "packages/docs/cource.config.ts",

      "packages/desktop-app/src/**/*",
      "packages/desktop-app/vite.config.ts",

      "packages/ui/src/**/*",

      "packages/datemath/**/src/**/*",
      "packages/datemath/vite.config.ts",

      "!packages/**/src/routeTree.gen.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
