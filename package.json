{
  "name": "citric",
  "private": true,
  "scripts": {
    "build:cli:prod": "./scripts/build-cli-prod.sh",
    "build:cli:dev": "./scripts/build-cli-dev.sh",
    "build:cli": "pnpm build:cli:dev && pnpm build:cli:prod",
    "dev:app": "cd packages/app && pnpm dev",
    "build": "pnpm -r build",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "postinstall": "lefthook install",
    "test": "vitest",
    "test:watch": "vitest --watch --ui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "4.0.18",
    "lefthook": "^2.1.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.29.3"
}
