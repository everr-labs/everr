{
  "name": "everr",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --dir packages/app dev",
    "dev:desktop": "pnpm --dir packages/everr-app tauri dev",
    "build:web:prod": "pnpm --dir packages/app build",
    "build:release:prod": "pnpm run build:cli:prod && pnpm run build:desktop:prod",
    "build:cli:prod": "./scripts/build-cli-prod.sh",
    "build:cli:dev": "./scripts/build-cli-dev.sh",
    "build:desktop:prod": "./scripts/build-everr-app.sh",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "postinstall": "lefthook install",
    "test": "vitest",
    "test:watch": "vitest --watch --ui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "4.0.18",
    "lefthook": "^2.1.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.29.3"
}
