{
	"extends": "@citric/tsconfig/base.json",

	"compilerOptions": {
		"allowSyntheticDefaultImports": true,

		/* Bundled projects */
		"lib": ["dom", "dom.iterable", "ES2022"],
		"module": "ESNext",
		"jsx": "react-jsx",

		/* Path Aliases */
		"baseUrl": ".",
		"paths": {
			"@/components/*": ["./src/components/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules"]
}
