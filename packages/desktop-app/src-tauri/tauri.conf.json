{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Everr App",
  "version": "0.1.0",
  "identifier": "dev.everr.everr-app",
  "build": {
    "beforeDevCommand": "pnpm desktop:prepare:debug && pnpm frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm desktop:prepare:release && pnpm frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Everr App",
        "width": 620,
        "height": 560,
        "minWidth": 520,
        "minHeight": 500,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "externalBin": ["binaries/everr"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
