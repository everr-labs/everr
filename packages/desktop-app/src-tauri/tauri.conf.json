{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Everr",
  "version": "0.1.22",
  "identifier": "dev.everr.everr-app",
  "build": {
    "beforeDevCommand": "pnpm desktop:prepare:debug && pnpm frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm desktop:prepare:release && pnpm frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "backgroundColor": "#0A0A0A",
        "title": "Everr",
        "width": 680,
        "height": 680,
        "minWidth": 680,
        "minHeight": 680,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 20
        }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDQUU1NEE0OTM2MTlCQzEKUldUQm0yR1RwRlN1ckIzTXc4dm9QRWVFUUhtd3hTdmJJazBYSXVoQzlxcVNnRzJWQ3BneGhQZDkK",
      "endpoints": [
        "https://everr.dev/everr-app/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "../../../target/desktop-resources/everr": "everr"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
