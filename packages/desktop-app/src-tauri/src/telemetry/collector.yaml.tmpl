receivers:
  otlp:
    protocols:
      http:
        endpoint: 127.0.0.1:{OTLP_PORT}

processors:
  batch:
    timeout: 1s
    send_batch_size: 512

exporters:
  file:
    path: "{TELEMETRY_DIR}/otlp.json"
    rotation:
      max_megabytes: 5
      max_backups: 200
      localtime: false
    format: json

extensions:
  health_check:
    endpoint: 127.0.0.1:{HEALTH_PORT}

service:
  extensions: [health_check]
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [file]
    logs:
      receivers: [otlp]
      processors: [batch]
      exporters: [file]
  telemetry:
    metrics:
      level: none
    logs:
      level: warn
