{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the Everr tray app",
  "windows": ["main", "notification"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "../../../target/desktop-sidecars/everr-local-collector",
          "sidecar": true
        }
      ]
    }
  ]
}
