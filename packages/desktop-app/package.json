{
  "name": "@everr/desktop-app",
  "private": true,
  "version": "0.1.30",
  "type": "module",
  "scripts": {
    "dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "watch": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "desktop:prepare:cli:debug": "node ./scripts/prepare-tauri-cli-sidecar.ts debug",
    "desktop:prepare:cli:release": "node ./scripts/prepare-tauri-cli-sidecar.ts release",
    "desktop:prepare:debug": "pnpm run desktop:prepare:cli:debug",
    "desktop:prepare:release": "pnpm run desktop:prepare:cli:release",
    "build:desktop": "node ./scripts/build-desktop.ts",
    "build:desktop:ci": "node ./scripts/build-desktop.ts --ci",
    "build:cli:debug": "node ./scripts/build-cli.ts debug",
    "build:cli:release": "node ./scripts/build-cli.ts release",
    "install:cli:debug": "node ./scripts/build-cli.ts debug --install",
    "install:cli:release": "node ./scripts/build-cli.ts release --install",
    "frontend:dev": "vite",
    "frontend:build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@everr/datemath": "workspace:*",
    "@everr/ui": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "1.169.1",
    "@tauri-apps/api": "^2.11.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "^29.1.1",
    "semver": "^7.7.4",
    "typescript": "catalog:",
    "vite": "catalog:",
    "zx": "^8.8.5"
  }
}
