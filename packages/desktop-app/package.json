{
  "name": "@everr/desktop-app",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "watch": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "desktop:prepare:debug": "node ./scripts/prepare-tauri-cli-sidecar.ts debug",
    "desktop:prepare:release": "node ./scripts/prepare-tauri-cli-sidecar.ts release",
    "build:desktop": "node ./scripts/build-desktop.ts",
    "build:cli:debug": "node ./scripts/build-cli.ts debug",
    "build:cli:release": "node ./scripts/build-cli.ts release",
    "install:cli:debug": "node ./scripts/build-cli.ts debug --install",
    "install:cli:release": "node ./scripts/build-cli.ts release --install",
    "frontend:dev": "vite",
    "frontend:build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@radix-ui/themes": "^3.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tauri-apps/api": "^2",
    "better-themes": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^28.1.0",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.18",
    "zx": "^8.8.4"
  }
}
