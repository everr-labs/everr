{
	"extends": "@citric/tsconfig/base.json",

	"compilerOptions": {
		"target": "ESNext",
		"allowSyntheticDefaultImports": true,
		"types": ["vinxi/types/client"],

		/* Bundled projects */
		"lib": ["dom", "dom.iterable", "ES2022"],
		"module": "ESNext",
		"jsx": "react-jsx",

		/* Path Aliases */
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/app/*"],
			"~server/*": ["./src/server/*"]
		}
	},
	"include": ["."],
	"exclude": ["node_modules"]
}
