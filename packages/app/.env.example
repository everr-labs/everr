# PostgreSQL
DATABASE_HOST="localhost"
DATABASE_NAME="postgres"
DATABASE_PORT="5432"
DATABASE_USER="postgres"
DATABASE_PASSWORD="postgres"
DATABASE_SSL="false"

# ClickHouse
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_USERNAME="app_ro"
CLICKHOUSE_PASSWORD="app-dev"
CLICKHOUSE_DATABASE="app"

WORKOS_CLIENT_ID=client_dev_replace_me
WORKOS_API_KEY=client_dev_replace_me
WORKOS_REDIRECT_URI="http://localhost:5173/api/auth/callback"
# Minimum 32 characters. Example: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD="replace-with-a-long-random-value"
EVERR_API_BASE_URL="http://localhost:5173"

# GitHub App install flow
GITHUB_APP_INSTALL_URL="https://github.com/apps/<your-app-slug>/installations/new"
# Minimum 32 characters. Example: openssl rand -base64 24
GITHUB_APP_STATE_SECRET="replace-with-a-long-random-value"
# Minimum 32 characters. Must match your GitHub App webhook secret.
GITHUB_APP_WEBHOOK_SECRET="replace-with-a-long-random-value"
# Found on your GitHub App's settings page (General → App ID)
GITHUB_APP_ID="123456"
# Generate a private key on your GitHub App's settings page, paste the .pem contents here
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# GitHub webhook worker
INGRESS_COLLECTOR_URL="http://localhost:8080/webhook/github"
INGRESS_SOURCE="github"
INGRESS_WORKER_COUNT="2"
INGRESS_WORKER_BATCH_SIZE="10"
INGRESS_MAX_ATTEMPTS="10"
INGRESS_POLL_INTERVAL="2s"
INGRESS_LOCK_DURATION="120s"
INGRESS_REPLAY_TIMEOUT="30s"
INGRESS_TENANT_CACHE_TTL="60s"
INGRESS_RETENTION_DONE_DAYS="7"
INGRESS_RETENTION_DEAD_DAYS="30"
INGRESS_CLEANUP_INTERVAL="1h"
