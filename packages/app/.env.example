# Node environment
NODE_ENV="development"

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/default"

# ClickHouse
CLICKHOUSE_HOST="localhost"
CLICKHOUSE_PORT="8123"
CLICKHOUSE_USERNAME="app_ro"
CLICKHOUSE_PASSWORD="app-dev"
CLICKHOUSE_DATABASE="app"

WORKOS_CLIENT_ID=client_dev_replace_me
WORKOS_API_KEY=client_dev_replace_me
WORKOS_REDIRECT_URI="http://localhost:5173/api/auth/callback"
# Minimum 32 characters. Example: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD="replace-with-a-long-random-value"
EVERR_API_BASE_URL="http://localhost:5173"

# GitHub App install flow
GITHUB_APP_INSTALL_URL="https://github.com/apps/<your-app-slug>/installations/new"
# Minimum 32 characters. Example: openssl rand -base64 24
GITHUB_APP_STATE_SECRET="replace-with-a-long-random-value"
# Minimum 32 characters. Must match your GitHub App webhook secret.
GITHUB_APP_WEBHOOK_SECRET="replace-with-a-long-random-value"
# Minimum 32 characters. Must match ingress `INGRESS_TENANT_RESOLUTION_SECRET`.
INGRESS_TENANT_RESOLUTION_SECRET="replace-with-a-long-random-value"
