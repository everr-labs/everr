{
	"$schema": "https://turborepo.org/schema.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".vinxi/**"]
		},
		"dev": {
			"persistent": true,
			"env": [
				"NODE_ENV",
				"CLICKHOUSE_PASSWORD",
				"CLICKHOUSE_USER",
				"CLICKHOUSE_DB",
				"CLICKHOUSE_URL",
				"DB_URL",
				"GITHUB_CLIENT_ID",
				"GITHUB_CLIENT_SECRET"
			]
		}
	}
}
