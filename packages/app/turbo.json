{
	"$schema": "https://turborepo.org/schema.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".vinxi/**"]
		},
		"dev": {
			"persistent": true,
			"env": [
				"MODE",
				"GITHUB_CLIENT_ID",
				"GITHUB_CLIENT_SECRET",
				"BETTER_AUTH_SECRET",
				"BETTER_AUTH_URL",
				"DATABASE_URL",
				"GRAFANA_API_BASE_URL",
				"GRAFANA_TOKEN",
				"CLICKHOUSE_PASSWORD",
				"CLICKHOUSE_DB",
				"CLICKHOUSE_USER",
				"CLICKHOUSE_URL"
			]
		}
	}
}
