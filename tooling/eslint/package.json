{
	"name": "@citric/eslint-config",
	"private": true,
	"version": "0.3.0",
	"type": "module",
	"exports": {
		"./base": "./base.js",
		"./react": "./react.js"
	},
	"scripts": {
		"clean": "git clean -xdf .cache node_modules",
