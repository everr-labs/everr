		"eslint-plugin-react-hooks": "5.1.0",
		"eslint-plugin-turbo": "^2.4.3",
		"typescript-eslint": "^8.25.0"
	},
	"devDependencies": {
		"@citric/prettier-config": "workspace:*",
		"@citric/tsconfig": "workspace:*",
		"eslint": "catalog:",
		"typescript": "catalog:"
	},
	"prettier": "@citric/prettier-config"
