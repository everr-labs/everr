{
  "name": "@everr/action",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && ncc build src/index.ts -o dist",
    "clean": "node --input-type=commonjs -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});\"",
    "test": "pnpm run typecheck && node --test src/index.test.ts scripts/finalize.test.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@actions/artifact": "2.2.2",
    "@actions/core": "1.11.1",
    "js-yaml": "4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.5.2",
    "@vercel/ncc": "0.38.4",
    "typescript": "catalog:"
  }
}
