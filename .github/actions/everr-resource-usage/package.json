{
  "name": "everr-resource-usage-action",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run clean && npm run build:compile && npm run build:bundle && npm run build:finalize",
    "build:bundle": "ncc build build/src/index.js -o dist && node --input-type=commonjs -e \"require('node:fs').renameSync('dist/index.js','dist/index.mjs');\"",
    "build:compile": "tsc -p tsconfig.json",
    "build:finalize": "node --input-type=commonjs -e \"const fs=require('node:fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('build/scripts/finalize.js','dist/finalize.mjs');\"",
    "clean": "node --input-type=commonjs -e \"for (const dir of ['build','dist']) require('node:fs').rmSync(dir,{recursive:true,force:true});\"",
    "test": "npm run typecheck && node --test src/index.test.ts scripts/finalize.test.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@actions/artifact": "2.2.2",
    "@actions/core": "1.11.1",
    "js-yaml": "4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.5.2",
    "@vercel/ncc": "0.38.4",
    "typescript": "5.9.3"
  }
}
