{
	"$schema": "https://turborepo.org/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".cache/tsbuildinfo.json", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": false
		},
		"format": {
			"outputs": [".cache/.prettiercache"],
			"outputLogs": "new-only"
		},
		"lint": {
			"dependsOn": ["^build"],
			"outputs": [".cache/.eslintcache"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": [".cache/tsbuildinfo.json"]
		},
		"clean": {
			"cache": false
		},
		"//#clean": {
			"cache": false
		},
		"@citric/app#build": {
			"dependsOn": ["^build"],
			"outputs": ["packages/app/.output/**"]
		},
		"@citric/app#db:force-push": {
			"cache": false,
			"interactive": false,
			"env": ["DB_URL"]
		},
		"@citric/app#dev": {
			"persistent": true,
			"env": [
				"NODE_ENV",
				"BASE_URL",
				"VITE_BETTER_AUTH_URL",
				"CLICKHOUSE_PASSWORD",
				"CLICKHOUSE_USER",
				"CLICKHOUSE_DB",
				"CLICKHOUSE_URL",
				"DB_URL",
				"GITHUB_CLIENT_ID",
				"GITHUB_CLIENT_SECRET"
			]
		},
		"@citric/app#start": {
			"cache": false,
			"persistent": true,
			"env": [
				"NODE_ENV",
				"BASE_URL",
				"VITE_BETTER_AUTH_URL",
				"CLICKHOUSE_PASSWORD",
				"CLICKHOUSE_USER",
				"CLICKHOUSE_DB",
				"CLICKHOUSE_URL",
				"DB_URL",
				"GITHUB_CLIENT_ID",
				"GITHUB_CLIENT_SECRET"
			]
		},
		"studio": {
			"cache": false,
			"persistent": true
		}
	}
}
